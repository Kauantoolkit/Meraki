# Database Configuration (docker-compose postgres:15 em localhost:5433)
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=meraki_payment

# Node Environment
NODE_ENV=development

# Server
PORT=3002

# JWT (if needed)
JWT_SECRET=your_jwt_secret_here

# PIX Integration
PIX_API_KEY=your_pix_api_key
PIX_PROVIDER=banco_do_brasil  # or itau, bradesco, etc
