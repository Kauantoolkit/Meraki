# ─── Infraestrutura compartilhada (RabbitMQ) ───────────────────────────────
# Usado por: docker-compose.infra.yml
# Copie para .env e preencha: cp .env.infra.example .env

RABBITMQ_USER=meraki_user
RABBITMQ_PASS=CHANGE_ME   # openssl rand -base64 32
RABBITMQ_ERLANG_COOKIE=CHANGE_ME   # openssl rand -base64 32
