# ─── identity-service — desenvolvimento local ─────────────────────────────────
# Usado quando o serviço roda FORA do docker-compose (ex: npm run start:dev).
# Em produção, as variáveis são injetadas pelo docker-compose.prod.yml.
#
# ATENÇÃO: Este serviço usa DB_USERNAME/DB_PASSWORD (padrão TypeORM),
#          enquanto os outros serviços usam DB_USER/DB_PASS.
# ──────────────────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=development

# PostgreSQL (porta 5432 — banco exclusivo deste serviço)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=identity_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT — este serviço assina os tokens; todos os outros apenas validam
JWT_SECRET=meraki-jwt-secret-dev-only
JWT_EXPIRES_IN=7d

# RabbitMQ
RABBITMQ_URL=amqp://meraki:meraki@localhost:5672
