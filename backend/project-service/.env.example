# ─── project-service — variáveis de ambiente ───────────────────────────────
# Copie para .env e preencha: cp .env.example .env
#
# Deploy isolado (servidor próprio):
#   - DB_HOST não precisa ser alterado (container sobe junto)
#   - RABBITMQ_URL deve apontar para o servidor de infra externo
#
# Desenvolvimento local (fora do docker-compose):
#   - Suba o RabbitMQ via backend/docker-compose.infra.yml
#   - Deixe DB_HOST=localhost e DB_PORT=5432

PORT=3002
NODE_ENV=production

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=project_db
DB_USER=postgres
DB_PASS=CHANGE_ME   # openssl rand -base64 32

# JWT — deve ser idêntico em TODOS os serviços da plataforma
JWT_SECRET=CHANGE_ME   # openssl rand -base64 64

# RabbitMQ — aponte para o servidor de infra
# Exemplo: amqp://meraki_user:senha@192.168.1.10:5672
RABBITMQ_URL=amqp://RABBITMQ_USER:RABBITMQ_PASS@RABBITMQ_HOST:5672
