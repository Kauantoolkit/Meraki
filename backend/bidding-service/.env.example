# ─── bidding-service — desenvolvimento local ──────────────────────────────────
# Usado quando o serviço roda FORA do docker-compose (ex: npm run start:dev).
# Em produção, as variáveis são injetadas pelo docker-compose.prod.yml.
# ──────────────────────────────────────────────────────────────────────────────

PORT=3003
NODE_ENV=development

# PostgreSQL (porta 5434 — banco exclusivo deste serviço)
DB_HOST=localhost
DB_PORT=5434
DB_NAME=bidding_db
DB_USER=postgres
DB_PASS=postgres

# JWT — apenas valida tokens emitidos pelo identity-service
JWT_SECRET=meraki-jwt-secret-dev-only

# RabbitMQ
RABBITMQ_URL=amqp://meraki:meraki@localhost:5672
