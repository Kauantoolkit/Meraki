# ─── Meraki — Desenvolvimento local (monorepo) ─────────────────────────────
# Usado por: docker compose up (docker-compose.yml — todos os serviços juntos)
# Este arquivo é APENAS para desenvolvimento local em uma única máquina.
#
# Para deploy em servidores separados, use o .env.example de cada serviço
# individualmente e consulte DEPLOY.md.
#
# Copie para .env e ajuste: cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ─── Banco de dados ───────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASS=postgres

IDENTITY_DB_NAME=identity_db
PROJECT_DB_NAME=project_db
BIDDING_DB_NAME=bidding_db
DELIVERY_DB_NAME=delivery_db
PAYMENT_DB_NAME=payment_db
PORTFOLIO_DB_NAME=portfolio_db

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_USER=meraki
RABBITMQ_PASS=meraki
RABBITMQ_ERLANG_COOKIE=meraki-erlang-cookie-dev-only

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=meraki-jwt-secret-dev-only
JWT_EXPIRES_IN=7d

# ─── Negócio ─────────────────────────────────────────────────────────────────
PLATFORM_FEE_RATE=0.10
