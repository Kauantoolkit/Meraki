# ─── payment-service — desenvolvimento local ──────────────────────────────────
# Usado quando o serviço roda FORA do docker-compose (ex: npm run start:dev).
# Em produção, as variáveis são injetadas pelo docker-compose.prod.yml.
# ──────────────────────────────────────────────────────────────────────────────

PORT=3005
NODE_ENV=development

# PostgreSQL (porta 5436 — banco exclusivo deste serviço)
DB_HOST=localhost
DB_PORT=5436
DB_NAME=payment_db
DB_USER=postgres
DB_PASS=postgres

# JWT — apenas valida tokens emitidos pelo identity-service
JWT_SECRET=meraki-jwt-secret-dev-only

# RabbitMQ
RABBITMQ_URL=amqp://meraki:meraki@localhost:5672

# Taxa da plataforma aplicada a cada pagamento liberado (0.10 = 10%)
PLATFORM_FEE_RATE=0.10
