# ─── Meraki — Variáveis de PRODUÇÃO (docker-compose.prod.yml) ────────────────
#
# Copie para .env.production e preencha todos os valores antes do deploy.
# NUNCA commite .env.production no git — ele já está no .gitignore.
#
# Como usar:
#   cp .env.production.example .env.production
#   nano .env.production
#   ./deploy.sh
# ──────────────────────────────────────────────────────────────────────────────

# ─── Traefik / SSL ────────────────────────────────────────────────────────────
# Domínio público da API (sem https://, sem barra final)
DOMAIN=api.seudominio.com.br

# Email para alertas do Let's Encrypt (vencimento de certificado, etc.)
ACME_EMAIL=seu@email.com

# ─── Banco de dados ───────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 24 | tr -d '=+/' | head -c 32
DB_USER=meraki_user
DB_PASS=SENHA_FORTE_AQUI

# Nomes dos bancos — pode deixar como está
IDENTITY_DB_NAME=identity_db
PROJECT_DB_NAME=project_db
BIDDING_DB_NAME=bidding_db
DELIVERY_DB_NAME=delivery_db
PAYMENT_DB_NAME=payment_db
PORTFOLIO_DB_NAME=portfolio_db

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 24 | tr -d '=+/' | head -c 32
RABBITMQ_USER=meraki_rabbit
RABBITMQ_PASS=SENHA_FORTE_AQUI

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=SECRET_LONGO_E_ALEATORIO_AQUI
JWT_EXPIRES_IN=7d

# ─── Negócio ─────────────────────────────────────────────────────────────────
# Taxa da plataforma (0.10 = 10%)
PLATFORM_FEE_RATE=0.10

# ─── Backup ──────────────────────────────────────────────────────────────────
# Quantos dias de backup manter localmente (padrão: 7)
BACKUP_RETENTION_DAYS=7
