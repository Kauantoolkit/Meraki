# ─── api-gateway — variáveis de ambiente ───────────────────────────────────
# Copie para .env e preencha: cp .env.example .env
#
# O api-gateway é stateless — não tem banco de dados próprio.
# Configure as URLs dos microserviços apontando para os servidores reais.

PORT=3000
NODE_ENV=production

# JWT — deve ser idêntico ao JWT_SECRET configurado em todos os outros serviços
JWT_SECRET=CHANGE_ME   # openssl rand -base64 64

# URLs dos microserviços — substitua pelos IPs ou hostnames reais de cada servidor.
# Use HTTPS em produção se os servidores tiverem certificado.
# Exemplo com IP:      http://203.0.113.10:3001
# Exemplo com domínio: https://identity.meraki.com.br
IDENTITY_SERVICE_URL=http://IDENTITY_SERVER_IP:3001
PROJECT_SERVICE_URL=http://PROJECT_SERVER_IP:3002
BIDDING_SERVICE_URL=http://BIDDING_SERVER_IP:3003
DELIVERY_SERVICE_URL=http://DELIVERY_SERVER_IP:3004
PAYMENT_SERVICE_URL=http://PAYMENT_SERVER_IP:3005
PORTFOLIO_SERVICE_URL=http://PORTFOLIO_SERVER_IP:3006
