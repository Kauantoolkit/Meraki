# ─── api-gateway — desenvolvimento local ─────────────────────────────────────
# Usado quando o serviço roda FORA do docker-compose (ex: npm run start:dev).
# Em produção, as variáveis são injetadas pelo docker-compose.prod.yml.
# ──────────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# JWT — deve ser idêntico ao JWT_SECRET do identity-service
JWT_SECRET=meraki-jwt-secret-dev-only

# URLs dos microserviços internos
# Em docker-compose, mude localhost → nome do container (ex: identity-service)
IDENTITY_SERVICE_URL=http://localhost:3001
PROJECT_SERVICE_URL=http://localhost:3002
BIDDING_SERVICE_URL=http://localhost:3003
DELIVERY_SERVICE_URL=http://localhost:3004
PAYMENT_SERVICE_URL=http://localhost:3005
PORTFOLIO_SERVICE_URL=http://localhost:3006
