# ─── Variáveis de ambiente ────────────────────────────────────────────────────
# Ignora todos os arquivos .env e variantes; .env.example é explicitamente permitido
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# ─── Node.js ──────────────────────────────────────────────────────────────────
**/node_modules/
**/dist/
**/build/
**/*.js.map
**/coverage/
**/.nyc_output/
**/pids/
**/*.pid
**/*.seed
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# ─── Flutter / Dart ───────────────────────────────────────────────────────────
# Diretórios gerados pelo `flutter create` (plataformas nativas)
mobile/android/
mobile/ios/
mobile/linux/
mobile/macos/
mobile/windows/
mobile/web/

# Artefatos de build e ferramentas geradas
mobile/.dart_tool/
mobile/build/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/**/*.g.dart

# ─── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/settings.json
.vscode/launch.json

# ─── Sistemas operacionais ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.log

# ─── Produção ─────────────────────────────────────────────────────────────────
# Certificados SSL gerados pelo Traefik/Let's Encrypt
backend/traefik/letsencrypt/

# Backups dos bancos (ficam no volume Docker, não no repo)
backend/backups/

# ─── Documentos grandes (Office, ZIP, imagens de design) ──────────────────────
docs/**/*.zip
docs/**/*.docx
docs/**/*.xlsx
docs/**/*.png

# ─── Claude Code ──────────────────────────────────────────────────────────────
.claude/settings.local.json
